# ===========================
# Microshop Platform - Environment Variables
# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env
# ===========================

# --- PostgreSQL ---
POSTGRES_DB=shop
POSTGRES_USER=shop
POSTGRES_PASSWORD=shop_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE=orders.queue

# --- etcd (auth-service) ---
ETCD_ENDPOINTS=http://etcd:2379

# --- MinIO ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password
MINIO_BUCKET=shop-images
MINIO_ENDPOINT=http://minio:9000

# --- Auth Service (Go) ---
AUTH_PORT=8081
AUTH_SESSION_TTL_SECONDS=86400

# --- Backend (Java) ---
BACKEND_PORT=8080
BACKEND_JWT_SECRET=change_me_in_production

# --- Frontend (React) ---
FRONTEND_PORT=80
VITE_API_BASE=/api

# --- Gateway ---
GATEWAY_PORT=3000
